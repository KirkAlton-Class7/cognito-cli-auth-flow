# ============================================================
# ENVIRONMENT TEMPLATE
# ============================================================
# Cognito Auth Flow HTTPS Lab Environment Template
# Copy this file to .env, then update .env as you create resources.
# Do not commit .env with real account IDs, secrets, or lab-specific values.
# ------------------------------------------------------------

# ==============================================================
# INPUTS - PLANNED VALUES
# ==============================================================
# These are planned values that will be used in the deployment.
# Fill these in before deploying infrastructure.

# ------------------------------------------------------------
# 1. Foundational Inputs
# Fill these in with your information.
# ------------------------------------------------------------
REPO_ROOT=""
AWS_ACCOUNT_ID=""

# ------------------------------------------------------------
# 2. Core Lab Settings
# ------------------------------------------------------------
AWS_REGION="us-east-1"
PROJECT_NAME="chewbacca-auth-http"

TEST_USERNAME="chewbacca"
TEST_EMAIL="chewbacca@example.com"
TEST_PASSWORD="Wookiee#2026!"
TEMP_PASSWORD="Wookiee#TEMP1!"

# ------------------------------------------------------------
# 3. Planned Resource Names
# ------------------------------------------------------------
JEDI_FUNCTION="${PROJECT_NAME}-jedi-python"
SITH_FUNCTION="${PROJECT_NAME}-sith-node"

PYTHON_LAMBDA_ROLE_NAME="${PROJECT_NAME}-lambda-python-role"
NODE_LAMBDA_ROLE_NAME="${PROJECT_NAME}-lambda-node-role"

API_NAME="${PROJECT_NAME}-api"
USER_POOL_NAME="${PROJECT_NAME}-users"
DEFAULT_APP_CLIENT_NAME="${PROJECT_NAME}-users"
USER_POOL_CLIENT_NAME="${PROJECT_NAME}-cli-client"
AUTHORIZER_NAME="${PROJECT_NAME}-cognito-jwt"

# ==============================================================
# OUTPUTS - POST-DEPLOYMENT VALUES
# ==============================================================
# These are values generated after resources are created.
# Fill these in as you provision infrastructure.

# ------------------------------------------------------------
# 1. AWS IAM Outputs
# ------------------------------------------------------------
PYTHON_LAMBDA_ROLE_ARN=""
NODE_LAMBDA_ROLE_ARN=""

# ------------------------------------------------------------
# 2. Lambda Outputs
# ------------------------------------------------------------
JEDI_FUNCTION_ARN=""
SITH_FUNCTION_ARN=""

# ------------------------------------------------------------
# 3. HTTP API Gateway Outputs
# ------------------------------------------------------------
API_ID=""
API_ENDPOINT="https://${API_ID}.execute-api.${AWS_REGION}.amazonaws.com"
JEDI_INTEGRATION_ID=""
SITH_INTEGRATION_ID=""
JEDI_ROUTE_ID=""
SITH_ROUTE_ID=""

# ------------------------------------------------------------
# 4. Cognito Outputs
# ------------------------------------------------------------
USER_POOL_ID=""
USER_POOL_ARN="arn:aws:cognito-idp:${AWS_REGION}:${AWS_ACCOUNT_ID}:userpool/${USER_POOL_ID}"
COGNITO_ISSUER="https://cognito-idp.${AWS_REGION}.amazonaws.com/${USER_POOL_ID}"

DEFAULT_CLIENT_ID=""
COGNITO_PUBLIC_CLIENT_ID="${DEFAULT_CLIENT_ID}"

CLIENT_ID=""
CLIENT_SECRET=""

COGNITO_AUTHORIZER_ID=""

# ------------------------------------------------------------
# 5. Token Helper Script Values
# ------------------------------------------------------------
# These are stable inputs for helper scripts.
# Do not store JWTs here.

COGNITO_USERNAME="${TEST_USERNAME}"
COGNITO_PASSWORD="${TEST_PASSWORD}"
API_BASE="${API_ENDPOINT}/prod"
